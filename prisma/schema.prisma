generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String?
  listings  Listing[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Listing {
  id          Int       @id @default(autoincrement())
  title       String
  description String    @default("")
  price       Float
  buyPrice    Float     @default(0)
  condition   String    @default("Gut")
  category    String    @default("Sonstiges")
  brand       String    @default("")
  size        String    @default("")
  color       String    @default("")
  shipping    String    @default("[]")
  shipSize    String    @default("")
  status      String    @default("aktiv")
  platforms   String    @default("[]")
  images      String    @default("[]")
  views       Int       @default(0)
  days        Int       @default(0)
  relistedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlatformAccount {
  id        Int      @id @default(autoincrement())
  platform  String   @unique
  connected Boolean  @default(false)
  apiKey    String?
  username  String?
  data      String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id         Int   @id @default(1)
  relistDays Int   @default(5)
  dayGoal    Float @default(150)
  monthGoal  Float @default(500)
}
